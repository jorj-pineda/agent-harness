# Copy to .env and fill in. .env is gitignored.

# --- Providers ---
# Leave blank to disable a provider. The harness will pick up whichever are set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama runs locally; default host is fine for a normal install.
OLLAMA_HOST=http://localhost:11434

# Default provider when the API caller does not specify one.
DEFAULT_PROVIDER=ollama

# --- Model config ---
OLLAMA_MODEL=gemma4
OLLAMA_EMBED_MODEL=nomic-embed-text
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini
# Memory optimization: q8_0 KV cache cuts 32k context from ~15GB to ~5GB.
# Set this in the Ollama server environment (not read by the harness itself).
# OLLAMA_KV_CACHE_TYPE=q8_0

# --- Data paths ---
SQLITE_DB_PATH=data/support.db
CHROMA_PATH=data/chroma
MEMORY_DB_PATH=data/memory.db

# --- Harness budgets ---
MAX_TOOL_ITERATIONS=8
REQUEST_TIMEOUT_SECONDS=60

# --- Grounding ---
CONFIDENCE_ESCALATION_THRESHOLD=0.55

# --- Logging ---
LOG_LEVEL=INFO
